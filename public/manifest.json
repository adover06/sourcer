{
  "manifest_version": 3,
  "name": "QuickNav",
  "version": "0.1.0",
  "description": "Raycast-style command palette for Chrome — search tabs, history, and bookmarks instantly.",
  "permissions": ["history", "bookmarks", "tabs"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+K",
        "mac": "Command+K"
      },
      "description": "Open QuickNav command palette"
    }
  },
  "action": {
    "default_title": "QuickNav"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
