{
  "manifest_version": 3,
  "name": "Sourcer",
  "version": "0.1.0",
  "description": "Command palette for Chrome — instantly search tabs, history, and bookmarks.",
  "permissions": ["history", "bookmarks", "tabs", "scripting", "storage"],
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+K",
        "mac": "Command+K"
      },
      "description": "Open Sourcer command palette"
    }
  },
  "action": {
    "default_title": "Sourcer"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
